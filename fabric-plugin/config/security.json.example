{
  "_comment": "OPT-IN security policy. This file is OPTIONAL. With no config/security.json present, the plugin runs unrestricted. Copy this file to config/security.json and replace the placeholder workspace GUIDs to enable per-environment guardrails. Workspaces NOT listed here are 'unmanaged' and allowed (a [SECURITY] warning is printed). Only the two SQL skills (warehouse-query, warehouse-list) currently enforce these policies.",
  "version": "1.0",
  "default_policy": "read-only",
  "environments": {
    "prod": {
      "workspaces": [
        "00000000-0000-0000-0000-000000000000"
      ],
      "display_name": "WS_PROD_EXAMPLE",
      "allowed_operations": [
        "workspace:list",
        "workspace:get",
        "lakehouse:list",
        "lakehouse:get",
        "lakehouse:list-tables",
        "lakehouse:read-table",
        "lakehouse:query",
        "notebook:list",
        "notebook:get",
        "pipeline:list",
        "pipeline:get",
        "warehouse:list",
        "warehouse:get",
        "warehouse:query",
        "onelake:list-files",
        "onelake:download-file"
      ],
      "denied_operations": [
        "notebook:create",
        "notebook:update",
        "notebook:delete",
        "notebook:run",
        "pipeline:create",
        "pipeline:update",
        "pipeline:delete",
        "pipeline:run",
        "lakehouse:create",
        "lakehouse:update",
        "lakehouse:delete",
        "lakehouse:create-table",
        "lakehouse:insert-data",
        "warehouse:create",
        "warehouse:update",
        "warehouse:delete",
        "warehouse:execute-sql",
        "onelake:upload-file",
        "onelake:delete-file",
        "workspace:create",
        "workspace:update",
        "workspace:delete"
      ],
      "require_confirmation": true,
      "max_query_rows": 10000,
      "data_classification": "confidential"
    },
    "uat": {
      "workspaces": [
        "11111111-1111-1111-1111-111111111111"
      ],
      "display_name": "WS_UAT_EXAMPLE",
      "allowed_operations": [
        "workspace:list",
        "workspace:get",
        "lakehouse:list",
        "lakehouse:get",
        "lakehouse:list-tables",
        "lakehouse:read-table",
        "lakehouse:query",
        "notebook:list",
        "notebook:get",
        "notebook:run",
        "pipeline:list",
        "pipeline:get",
        "pipeline:run",
        "warehouse:list",
        "warehouse:get",
        "warehouse:query",
        "onelake:list-files",
        "onelake:download-file"
      ],
      "denied_operations": [
        "notebook:create",
        "notebook:update",
        "notebook:delete",
        "pipeline:create",
        "pipeline:update",
        "pipeline:delete",
        "lakehouse:create",
        "lakehouse:update",
        "lakehouse:delete",
        "lakehouse:create-table",
        "lakehouse:insert-data",
        "warehouse:create",
        "warehouse:update",
        "warehouse:delete",
        "warehouse:execute-sql",
        "onelake:upload-file",
        "onelake:delete-file",
        "workspace:create",
        "workspace:update",
        "workspace:delete"
      ],
      "require_confirmation": false,
      "max_query_rows": 100000,
      "data_classification": "internal"
    },
    "dev": {
      "workspaces": [
        "22222222-2222-2222-2222-222222222222"
      ],
      "display_name": "WS_DEV_EXAMPLE",
      "allowed_operations": [
        "*"
      ],
      "denied_operations": [],
      "require_confirmation": false,
      "max_query_rows": null,
      "data_classification": "internal"
    }
  },
  "audit": {
    "enabled": true,
    "log_file": "$TEMP/fabric-plugin-audit.jsonl",
    "log_all_operations": true,
    "log_failed_operations": true,
    "retention_days": 90
  },
  "safety_limits": {
    "max_concurrent_jobs": 5,
    "max_notebook_runtime_minutes": 60,
    "max_pipeline_runtime_minutes": 120,
    "max_data_export_mb": 100
  }
}
